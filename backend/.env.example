# ═══════════════════════════════════════════════════════════════════════════════
# CallScorerRYMSAI Backend Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── AUTHENTICATION & SECURITY ────────────────────────────────────────────────
# REQUIRED: OpenAI API key for Whisper transcription and GPT-4o scoring
# Get from: https://platform.openai.com/api-keys
# Must be kept secret, NEVER commit to git
OPENAI_API_KEY="sk-your-openai-api-key-here"

# REQUIRED: JWT signing secret for authentication tokens
# Must be: At least 32 characters, cryptographically random, kept secret in production
# Generate: openssl rand -base64 32
JWT_SECRET="change-this-to-a-very-strong-secret-with-at-least-32-chars"

# ─── DATABASE ──────────────────────────────────────────────────────────────────
# REQUIRED: PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Development: postgresql://postgres:postgres@localhost:5432/callscorerrymsai_db
# Docker Compose: postgresql://postgres:postgres@postgres:5432/callscorerrymsai_db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/callscorerrymsai_db"

# ─── REDIS (Async Queue) ───────────────────────────────────────────────────────
# Required for BullMQ audio processing queue
# Development: redis://localhost:6379
# Docker Compose: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ─── SERVER CONFIGURATION ──────────────────────────────────────────────────────
# HTTP port for Express server
PORT=3001

# Node environment: development | production | staging
NODE_ENV="development"

# ─── FILE UPLOADS ──────────────────────────────────────────────────────────────
# Directory where MP3 files are stored (must be absolute or relative to process.cwd())
# Development: ./secure-uploads
# Production: /app/secure-uploads (with persistent Docker volume)
UPLOADS_DIR="./secure-uploads"

# ─── SESSION & COOKIES ─────────────────────────────────────────────────────────
# Frontend URL (used for CORS whitelist and cookie domain configuration)
# Development: http://localhost:5173
# Production: https://app.recuperosymandatos.com
FRONTEND_URL="http://localhost:5173"

# JWT access token expiration (short-lived)
JWT_ACCESS_EXPIRES_IN="15m"

# JWT refresh token expiration (long-lived) - used for token rotation
JWT_REFRESH_EXPIRES_IN="7d"

# Cookie domain (leave empty for automatic detection: localhost in dev, domain in prod)
COOKIE_DOMAIN=""

# SameSite cookie attribute: strict | lax | none
COOKIE_SAME_SITE="lax"

# ─── OPTIONAL: SEED DATA (Prisma seed.ts) ─────────────────────────────────────
# When running 'npm run prisma:seed', these override hardcoded development passwords.
# Production MUST set these explicitly. Leave empty to use dev fallbacks (insecure).
# Defaults if not set: Admin1234 (admin), Gestor1234 (gestor)
SEED_ADMIN_PASSWORD="ChangeMe@12345"
SEED_GESTOR_PASSWORD="ChangeMe@12345"

