{
  "name": "callscorerrymsai-backend",
  "version": "1.0.0",
  "description": "Backend for CallScorerRYMSAI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=html tsx --test src/**/*.test.ts",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "scores:recalculate": "tsx src/scripts/recalculate-scores.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "scores:normalize-same-audio": "tsx src/scripts/normalize-same-audio-scores.ts",
    "audit": "npm audit --audit-level=high"
  },
  "prisma": {
    "seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.12",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "file-type": "^21.3.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.29.2",
    "pdfkit": "^0.15.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.28",
    "@types/pdfkit": "^0.13.4",
    "@types/uuid": "^9.0.8",
    "c8": "^10.1.3",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
