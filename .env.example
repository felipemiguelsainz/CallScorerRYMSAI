# ═══════════════════════════════════════════════════════════════════════════════
# CallScorerRYMSAI Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: Empty on first run, will be generated. Use only alphanumeric + special chars.
OPENAI_API_KEY=sk-your-openai-api-key-here

# REQUIRED: JWT signing secret. Minimum 32 characters. Change in production!
JWT_SECRET=change-this-to-a-strong-random-secret-with-at-least-32-characters

# ─── POSTGRES CONFIGURATION ───────────────────────────────────────────────────
# REQUIRED: Used by docker-compose for 'postgres' service initialization
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=callscorerrymsai_db

# REQUIRED: Database connection string for backend + worker
# Format: postgresql://user:password@host:port/database
# Development: postgresql://postgres:{POSTGRES_PASSWORD}@postgres:5432/callscorerrymsai_db
# Local: postgresql://postgres:{POSTGRES_PASSWORD}@localhost:5432/callscorerrymsai_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/callscorerrymsai_db

# ─── REDIS CONFIGURATION ──────────────────────────────────────────────────────
# Required by backend + worker for async queue processing
# Development/Docker: redis://redis:6379
# Local: redis://localhost:6379
REDIS_URL=redis://redis:6379

# ─── BACKEND RUNTIME ──────────────────────────────────────────────────────────
# API server port
PORT=3001

# NODE_ENV: development | production
NODE_ENV=production

# Frontend URL: Where the React app is served (for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# Directory where MP3 files are persisted (docker: /app/secure-uploads, local: ./secure-uploads)
UPLOADS_DIR=/app/secure-uploads

# ─── JWT TOKEN EXPIRATION ─────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── COOKIE CONFIGURATION ─────────────────────────────────────────────────────
# Leave empty for automatic (localhost in dev, domain in prod)
COOKIE_DOMAIN=

# CSRF protection
COOKIE_SAME_SITE=lax

# ─── FRONTEND CONFIGURATION ───────────────────────────────────────────────────
# Client-side API base URL (passed to Vite builder)
VITE_API_URL=http://localhost:3001

# ─── OPTIONAL: SEED CREDENTIALS (Production deployments only) ───────────────
# When running 'npm run prisma:seed', these override the hardcoded fallback passwords.
# Leave empty to use development defaults (not recommended for production).
# SEED_ADMIN_PASSWORD=ChangeMe@12345
# SEED_GESTOR_PASSWORD=ChangeMe@12345

