# ═══════════════════════════════════════════════════════════════════════════════
# CallerScorerRYMSAI Frontend Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED: Backend API base URL (used by React Query in api.service.ts)
# Development/Docker: http://localhost:3001
# Local: http://localhost:3001
# Production: https://api.recuperosymandatos.com
VITE_API_URL=http://localhost:3001

# Important Security Notes:
# - NEVER expose OPENAI_API_KEY or JWT_SECRET in frontend variables
# - Only VITE_API_URL is safe to expose (it's the API gateway)
# - Frontend communicates auth tokens via httpOnly cookies only
# - All OpenAI calls must be routed through the backend API

